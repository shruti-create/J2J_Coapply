# ---------------------------------------------------------------------------
# Backend (Netlify Functions) — Firebase Admin service account.
# These are SECRET. In production set them in: Netlify → Site → Environment variables.
# For local dev (`netlify dev`) put real values in a `.env` file (git-ignored).
#
# Get them from: Firebase Console → Project settings → Service accounts →
# "Generate new private key" → open the downloaded JSON.
# ---------------------------------------------------------------------------

FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com

# Paste the entire "private_key" value from the JSON, in double quotes, keeping
# the literal \n escape sequences (the backend converts \n back into newlines).
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...your key...\n-----END PRIVATE KEY-----\n"

# ---------------------------------------------------------------------------
# Frontend Firebase Web config — NOT secret (they ship in the browser), but kept
# in env so they aren't committed in index.html. The frontend fetches these at
# runtime from /.netlify/functions/config. Copy values from:
# Firebase Console → Project settings → General → Your apps → Web app → SDK config.
#
# Required:
FIREBASE_API_KEY=your-web-api-key
# FIREBASE_PROJECT_ID is reused from above (the admin section).
#
# Optional — sensible defaults are derived from FIREBASE_PROJECT_ID if omitted:
# FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
# FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
FIREBASE_APP_ID=1:1234567890:web:abcdef123456
# FIREBASE_MESSAGING_SENDER_ID=1234567890
# ---------------------------------------------------------------------------
