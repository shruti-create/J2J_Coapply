rules_version = '2';

// Bloom tracker security rules.
// Clients (browser, Firebase Web SDK) may READ when signed in, so the shared
// pool, community stats, and live feed can stream via onSnapshot.
// All WRITES are denied to clients — every mutation goes through the TypeScript
// Netlify Functions backend, which uses the Admin SDK and bypasses these rules.

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    match /applications/{appId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /feed/{eventId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /userProfiles/{userId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /userProfiles/{userId}/leetcodeProblems/{problemId} {
      allow read: if signedIn();
      allow write: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
